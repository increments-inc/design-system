---
/**
 * ColorSwatch — single swatch card showing a color, its token name, value, and role.
 * Used inside a grid on the Color foundations page.
 */

type Props = {
  token: string;
  value: string;
  role: string;
  inkColor?: 'light' | 'dark';
};

const { token, value, role, inkColor = 'light' } = Astro.props;
---

<article class={`swatch ink-${inkColor}`}>
  <div class="swatch-chip" style={`background: ${value};`}></div>
  <div class="swatch-meta">
    <code class="swatch-token">{token}</code>
    <p class="swatch-value">{value}</p>
    <p class="swatch-role">{role}</p>
  </div>
</article>

<style>
  .swatch {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-surface-card);
  }

  .swatch-chip {
    height: 96px;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .swatch-meta {
    padding: var(--space-9) var(--space-12) var(--space-10);
  }

  .swatch-token {
    display: inline-block;
    font-size: 12px;
    font-family: var(--font-mono);
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--color-brand-lime);
  }

  .swatch-value {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-mute);
  }

  .swatch-role {
    margin-top: var(--space-4);
    font-size: 12.5px;
    color: var(--color-text-body);
    line-height: 1.45;
  }
</style>
