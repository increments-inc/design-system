---
/**
 * Callout — forest-gradient inset box for highlighting rules, warnings, or aphorisms.
 * Variants: 'note' (default), 'warning', 'accent' (lime hero).
 */

type Props = {
  variant?: 'note' | 'warning' | 'accent';
  title?: string;
};

const { variant = 'note', title } = Astro.props;
---

<aside class={`callout callout--${variant}`}>
  {title && <h4 class="callout-title">{title}</h4>}
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border-radius: var(--radius-xl);
    padding: var(--space-12) var(--space-14);
    margin: var(--space-10) 0;
  }

  .callout--note {
    background: var(--gradient-forest);
    border: 1px solid var(--color-border-lime);
  }

  .callout--warning {
    background: var(--gradient-forest);
    border: 1px solid rgba(245, 193, 94, 0.3);
  }

  .callout--accent {
    background: var(--gradient-lime);
    color: var(--color-brand-ink-on-lime);
    box-shadow: var(--shadow-cta-panel);
  }

  .callout-title {
    font-size: 15px;
    font-weight: var(--type-weight-heavy);
    letter-spacing: -0.01em;
    color: var(--color-text-strong);
    margin-bottom: var(--space-4);
  }

  .callout--accent .callout-title {
    color: var(--color-brand-ink-on-lime);
  }

  .callout-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-body);
  }

  .callout--accent .callout-body {
    color: rgba(9, 16, 12, 0.82);
  }

  .callout-body :global(p + p) {
    margin-top: 0.8em;
  }

  .callout-body :global(code) {
    color: var(--color-brand-lime);
  }

  .callout--accent .callout-body :global(code) {
    color: var(--color-brand-forest);
    background: rgba(9, 16, 12, 0.08);
    border-color: rgba(9, 16, 12, 0.15);
  }
</style>
