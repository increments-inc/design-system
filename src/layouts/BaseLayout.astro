---
/**
 * BaseLayout — primary page shell.
 *
 * Structure:
 *   <Header>  (sticky)
 *   <Sidebar>   <main>  slot  </main>
 *   <Footer>
 */

import '../styles/global.css';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

type Props = {
  title: string;
  description?: string;
  eyebrow?: string;
};

const {
  title,
  description = 'Increments Inc. Enterprise Design System — brand foundations, components, and patterns.',
  eyebrow,
} = Astro.props;

const fullTitle = `${title} · Increments Inc. Design System`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Preconnect & fonts — Inter + Instrument Serif per §3.1 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    {eyebrow && <div class="sr-only">{eyebrow}</div>}
    <Header />
    <div class="page-shell">
      <Sidebar />
      <main class="page-main">
        <div class="page-main-inner">
          <slot />
        </div>
        <Footer />
      </main>
    </div>
  </body>
</html>

<style>
  .page-shell {
    display: flex;
    align-items: flex-start;
    min-height: calc(100vh - var(--layout-header));
  }

  .page-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .page-main-inner {
    flex: 1;
    width: 100%;
    max-width: var(--layout-content-max);
    margin: 0 auto;
    padding: var(--space-20) var(--space-14) var(--space-20);
  }

  @media (max-width: 900px) {
    .page-shell {
      flex-direction: column;
    }
    .page-main-inner {
      padding: var(--space-14) var(--space-9);
    }
  }
</style>
