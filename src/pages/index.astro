---
import BaseLayout from '../layouts/BaseLayout.astro';

/**
 * Landing page — hero + Brand Foundations + Brand Identity index cards.
 */

type LandingCard = {
  number: string;
  title: string;
  href: string;
  summary: string;
  status?: 'ready' | 'soon';
};

const foundationCards: LandingCard[] = [
  {
    number: '01',
    title: 'Introduction',
    href: '/foundations/introduction/',
    summary: 'What this design system is, who it\'s for, and how to apply it across product, marketing, and sales.',
  },
  {
    number: '02',
    title: 'Brand Essence',
    href: '/foundations/brand-essence/',
    summary: 'The mood, design principles, and north star that keep every surface consistent.',
  },
  {
    number: '03',
    title: 'Color',
    href: '/foundations/color/',
    summary: 'Dark-forest base, single lime accent, gradients, and semantic roles.',
  },
  {
    number: '04',
    title: 'Typography',
    href: '/foundations/typography/',
    summary: 'Inter for structure, Instrument Serif for emotional lift — and the italic-accent rule.',
  },
  {
    number: '05',
    title: 'Spacing & Layout',
    href: '/foundations/spacing-layout/',
    summary: 'Spacing scale, grid patterns, breakpoints, and the A4 print canvas.',
  },
  {
    number: '06',
    title: 'Radii & Elevation',
    href: '/foundations/radii-elevation/',
    summary: 'Radius tokens by role, shadow system with lime-tinted glows.',
  },
  {
    number: '07',
    title: 'Iconography',
    href: '/foundations/iconography/',
    summary: 'Lime tile + dark glyph pattern, approved glyph palette, restraint rules.',
  },
  {
    number: '08',
    title: 'Motion',
    href: '/foundations/motion/',
    summary: 'One animation — the status-tag pulse. Everything else stays still.',
  },
  {
    number: '09',
    title: 'Logo',
    href: '/foundations/logo/',
    summary: 'Inline-SVG pattern, sizing, clear-space, and the rules that keep exports clean.',
  },
  {
    number: '10',
    title: 'Voice & Content',
    href: '/foundations/voice-content/',
    summary: 'Copy ↔ design alignment. Italic-word headline pattern. Contact footer convention.',
  },
  {
    number: '11',
    title: 'Accessibility',
    href: '/foundations/accessibility/',
    summary: 'Contrast targets, focus states, keyboard navigation, motion preferences.',
  },
  {
    number: '12',
    title: 'Tokens',
    href: '/foundations/tokens/',
    summary: 'CSS custom properties and Figma variable names — single source of truth.',
  },
];

const identityCards: LandingCard[] = [
  {
    number: '01',
    title: 'Introduction',
    href: '/brand-identity/introduction/',
    summary: 'What the Brand Identity layer is and how to use its 18 pages.',
    status: 'ready',
  },
  {
    number: '02',
    title: 'Brand Story',
    href: '/brand-identity/brand-story/',
    summary: 'The 10-year origin — why Increments exists and what it was built to replace.',
    status: 'ready',
  },
  {
    number: '03',
    title: 'Mission · Vision · Values',
    href: '/brand-identity/mission-vision-values/',
    summary: 'Three north stars and six non-negotiable values we check every hard decision against.',
    status: 'ready',
  },
  {
    number: '04',
    title: 'Positioning',
    href: '/brand-identity/positioning/',
    summary: 'Who we are, who we serve, what we replace, what makes us different — in one formal statement.',
    status: 'ready',
  },
  {
    number: '05',
    title: 'Target Audiences',
    href: '/brand-identity/target-audiences/',
    summary: 'Three personas with JTBD quotes: the operator-founder, the channel partner, the enterprise buyer.',
    status: 'ready',
  },
  {
    number: '06',
    title: 'Brand Personality',
    href: '/brand-identity/brand-personality/',
    summary: 'Archetype, attributes, and the deep expansion of how Increments feels.',
    status: 'soon',
  },
  {
    number: '07',
    title: 'Voice in Depth',
    href: '/brand-identity/voice-in-depth/',
    summary: 'Vocabulary, cadence, sentence shapes, before/after rewrites.',
    status: 'soon',
  },
  {
    number: '08',
    title: 'Tone by Context',
    href: '/brand-identity/tone-by-context/',
    summary: 'Sales · support · partner · social · crisis — how tone shifts without breaking voice.',
    status: 'soon',
  },
  {
    number: '09',
    title: 'Messaging Framework',
    href: '/brand-identity/messaging-framework/',
    summary: 'Key messages by audience, proof points, boilerplates.',
    status: 'soon',
  },
  {
    number: '10',
    title: 'Taglines & Copy Blocks',
    href: '/brand-identity/taglines/',
    summary: 'Elevator pitches at 30s / 60s / 2min, official taglines, ready-to-paste blocks.',
    status: 'soon',
  },
  {
    number: '11',
    title: 'Logo Applications',
    href: '/brand-identity/logo-applications/',
    summary: 'Profile vs cover, favicon, app icon, platform-specific sizes.',
    status: 'soon',
  },
  {
    number: '12',
    title: 'Social Media Playbook',
    href: '/brand-identity/social-media/',
    summary: 'LinkedIn, Instagram, X, YouTube — one consolidated playbook.',
    status: 'soon',
  },
  {
    number: '13',
    title: 'Content Strategy',
    href: '/brand-identity/content-strategy/',
    summary: 'Pillars, mix ratios, cadence, engagement rules.',
    status: 'soon',
  },
  {
    number: '14',
    title: 'Photography',
    href: '/brand-identity/photography/',
    summary: 'Why Increments stays photoless — and what we use instead.',
    status: 'soon',
  },
  {
    number: '15',
    title: 'Presentations & Docs',
    href: '/brand-identity/presentations/',
    summary: 'Deck templates, proposal style, email signatures, PDF layout.',
    status: 'soon',
  },
  {
    number: '16',
    title: 'Partner & Co-Branding',
    href: '/brand-identity/co-branding/',
    summary: 'Rules for partners using the mark; lockup patterns.',
    status: 'soon',
  },
  {
    number: '17',
    title: 'Trademark & Legal',
    href: '/brand-identity/trademark-legal/',
    summary: 'Third-party citation, attribution, what\'s protected.',
    status: 'soon',
  },
  {
    number: '18',
    title: 'Versioning & Requests',
    href: '/brand-identity/versioning/',
    summary: 'Who owns brand, approval workflow, changelog, version history.',
    status: 'soon',
  },
];
---

<BaseLayout
  title="Design System"
  description="Increments Inc. Enterprise Design System — brand foundations, components, patterns, and tokens."
>
  <section class="hero">
    <span class="hero-kicker">10-Year Anniversary · v0.2</span>
    <h1 class="hero-title">
      The <em>Increments</em> Design System.
    </h1>
    <p class="hero-lede">
      A single source of truth for every product screen, marketing flyer, deck, landing page,
      and email we ship. Dark, premium, opinionated — and built to scale across every surface.
    </p>

    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="hero-meta-value">12</span>
        <span class="hero-meta-label">Brand<br />Foundations</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-value">18</span>
        <span class="hero-meta-label">Brand<br />Identity</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-value">30+</span>
        <span class="hero-meta-label">Components<br />(coming)</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-value">15</span>
        <span class="hero-meta-label">Patterns<br />(coming)</span>
      </div>
    </div>
  </section>

  <section class="foundations">
    <div class="foundations-head">
      <span class="eyebrow">Part I · Ready now</span>
      <h2 class="foundations-title">Brand <em>Foundations</em></h2>
      <p class="foundations-lede">
        The building blocks — color, type, space, shadow, motion, and the copy conventions
        that connect them. Everything else in the system is derived from these 12 pages.
      </p>
    </div>

    <div class="foundations-grid">
      {foundationCards.map((card) => (
        <a href={card.href} class="foundation-card">
          <span class="foundation-card-number">{card.number}</span>
          <h3 class="foundation-card-title">{card.title}</h3>
          <p class="foundation-card-summary">{card.summary}</p>
          <span class="foundation-card-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="foundations">
    <div class="foundations-head">
      <span class="eyebrow">Part II · Wave 1 shipped · 13 more coming</span>
      <h2 class="foundations-title">Brand <em>Identity</em></h2>
      <p class="foundations-lede">
        Above the visual system: who we are, how we speak, and where we show up.
        Strategy, expression, applied identity, and protection — eighteen pages
        shipping in four waves through 2026.
      </p>
    </div>

    <div class="foundations-grid">
      {identityCards.map((card) => {
        const isSoon = card.status === 'soon';
        return (
          <a
            href={isSoon ? '#' : card.href}
            class={`foundation-card ${isSoon ? 'is-soon' : ''}`}
            aria-disabled={isSoon ? 'true' : undefined}
          >
            <span class="foundation-card-number">{card.number}</span>
            <h3 class="foundation-card-title">{card.title}</h3>
            <p class="foundation-card-summary">{card.summary}</p>
            <span class="foundation-card-arrow" aria-hidden="true">
              {isSoon ? 'soon' : '→'}
            </span>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-16);
    max-width: 840px;
  }

  .hero-kicker {
    display: inline-block;
    font-size: var(--type-caption);
    font-weight: var(--type-weight-bold);
    letter-spacing: var(--type-tracking-caps);
    text-transform: uppercase;
    color: var(--color-brand-lime);
    margin-bottom: var(--space-9);
  }

  .hero-title {
    font-size: clamp(42px, 6vw, 68px);
    font-weight: var(--type-weight-black);
    letter-spacing: var(--type-tracking-tight);
    line-height: 1.02;
    color: var(--color-text-strong);
  }

  .hero-title em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: var(--type-weight-regular);
    color: var(--color-brand-lime);
    letter-spacing: -0.02em;
  }

  .hero-lede {
    margin-top: var(--space-10);
    font-size: 19px;
    line-height: 1.55;
    color: var(--color-text-body);
    max-width: 62ch;
  }

  .hero-meta {
    margin-top: var(--space-16);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-9);
    padding: var(--space-10) 0;
    border-top: 1px solid var(--color-border-soft);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-meta-value {
    font-size: 36px;
    font-weight: var(--type-weight-black);
    letter-spacing: -0.04em;
    color: var(--color-brand-lime);
    line-height: 1;
  }

  .hero-meta-label {
    font-size: 10.5px;
    font-weight: var(--type-weight-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    line-height: 1.35;
  }

  .foundations {
    margin-top: var(--space-20);
  }

  .foundations-head {
    margin-bottom: var(--space-16);
  }

  .foundations-title {
    margin-top: var(--space-3);
    font-size: clamp(30px, 3.5vw, 40px);
    font-weight: var(--type-weight-black);
    letter-spacing: var(--type-tracking-tight);
    line-height: 1.08;
  }

  .foundations-title em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: var(--type-weight-regular);
    color: var(--color-brand-lime);
  }

  .foundations-lede {
    margin-top: var(--space-6);
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--color-text-body);
    max-width: 66ch;
  }

  .foundations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-9);
  }

  .foundation-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-12) var(--space-14) var(--space-12);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-xl);
    color: var(--color-text-body);
    text-decoration: none;
    transition: transform var(--motion-default) var(--motion-ease),
      border-color var(--motion-default) var(--motion-ease),
      background var(--motion-default) var(--motion-ease);
    overflow: hidden;
  }

  .foundation-card:hover {
    border-color: var(--color-border-lime);
    transform: translateY(-2px);
    background: var(--color-surface-card-deep);
  }

  .foundation-card.is-soon {
    opacity: 0.5;
    pointer-events: none;
    cursor: default;
  }

  .foundation-card.is-soon .foundation-card-arrow {
    font-family: var(--font-display);
    font-size: 9.5px;
    font-weight: var(--type-weight-bold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    border: 1px solid var(--color-border-soft);
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    align-self: flex-start;
  }

  .foundation-card-number {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: var(--type-weight-regular);
    font-size: 20px;
    color: var(--color-brand-lime);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .foundation-card-title {
    font-size: 20px;
    font-weight: var(--type-weight-heavy);
    color: var(--color-text-strong);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .foundation-card-summary {
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--color-text-body);
    max-width: none;
  }

  .foundation-card-arrow {
    display: inline-block;
    margin-top: var(--space-9);
    font-size: 18px;
    color: var(--color-brand-lime);
    transition: transform var(--motion-default) var(--motion-ease);
  }

  .foundation-card:hover .foundation-card-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 880px) {
    .foundations-grid {
      grid-template-columns: 1fr 1fr;
    }
    .hero-meta {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
  }

  @media (max-width: 560px) {
    .foundations-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
